<Window x:Class="LogisticsApp.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LogisticAppMain" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верх -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Лево верх -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Name="BtnCreateNew" Content="Create new" Width="100" Height="30" Margin="0,0,10,0" Click="BtnCreateNew_Click"/>
                <Button Content="Refresh" Width="80" Height="30" Margin="0,0,10,0" Click="BtnLoadOrders_Click"/>
                <Button Content="Find" Width="120" Height="30" Margin="0,0,10,0" Click="BtnOpenFindWindow_Click"/>
                <Button Name="BtnExportExcel" Content="📊 Export Excel" Width="110" Height="30" Margin="0,0,10,0" Click="BtnExportExcel_Click"/>
                <Button Name="BtnDeleteOrder" Content="Delete" Width="80" Height="30" Margin="0,0,10,0" Click="BtnDeleteOrder_Click"/>
            </StackPanel>

            <!-- Право верх -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Name="TxtLoginedUser" Text="User: -" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                <Button Content="⎋" Width="25" Height="25" BorderThickness="0" Click="BtnLogout_Click" ToolTip="Sign out and change user"/>
            </StackPanel>
        </Grid>

        <!-- Таблица -->
        <DataGrid Name="OrdersGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" MouseDoubleClick="OrdersGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Order №" Binding="{Binding OrderNumber}" Width="150"/>
                <DataGridTextColumn Header="Brief description" Binding="{Binding BriefDescription}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>