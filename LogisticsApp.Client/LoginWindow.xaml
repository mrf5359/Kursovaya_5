<Window x:Class="LogisticsApp.Client.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Login" Height="350" Width="300" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="30" VerticalAlignment="Center">
        <TextBlock Text="Logistics System" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Text="Username:" Margin="0,0,0,5"/>
        <TextBox Name="TxtUsername" Height="25" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

        <TextBlock Text="Password:" Margin="0,0,0,5"/>
        <PasswordBox Name="TxtPassword" Height="25" Margin="0,0,0,25" VerticalContentAlignment="Center"/>

        <Button Content="Login" Height="35" Background="#4CAF50" Foreground="White" FontSize="16" FontWeight="Bold" Click="BtnLogin_Click"/>

        <TextBlock Name="TxtError" Foreground="Red" HorizontalAlignment="Center" Margin="0,15,0,0" Visibility="Collapsed"/>
    </StackPanel>
</Window>