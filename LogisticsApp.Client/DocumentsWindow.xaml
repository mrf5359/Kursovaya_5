<Window x:Class="LogisticsApp.Client.DocumentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cloud Documents" Height="400" Width="450" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Attached PDF Documents (Cloudflare R2)" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <ListBox Name="ListDocuments" Grid.Row="1" Margin="0,0,0,15" DisplayMemberPath="FileName" FontSize="14"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="⬆ Upload PDF" Width="110" Height="35" Margin="0,0,10,0" Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="BtnUpload_Click"/>
            <Button Content="🗑 Delete" Width="90" Height="35" Margin="0,0,10,0" Background="#FF5252" Foreground="White" FontWeight="Bold" Click="BtnDelete_Click"/>
            <Button Content="👁 View / Download" Width="140" Height="35" Background="#2196F3" Foreground="White" FontWeight="Bold" Click="BtnView_Click"/>
        </StackPanel>
    </Grid>
</Window>